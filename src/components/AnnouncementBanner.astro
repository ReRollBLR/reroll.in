---
interface Props {
  text: string;
  ctaText: string;
  ctaHref: string;
}

const { text, ctaText, ctaHref } = Astro.props;
---

<div
  id="announcement-banner"
  role="region"
  aria-label="Site announcement"
  class="announcement-banner"
>
  <!-- Mobile: marquee text + CTA on separate lines -->
  <div class="announcement-mobile">
    <div class="marquee-track" aria-hidden="true">
      <div class="marquee-content">
        <span class="announcement-suit">♦</span>
        <span class="marquee-text">{text}</span>
        <span class="announcement-suit">♦</span>
        <span class="marquee-text">{text}</span>
        <span class="announcement-suit">♦</span>
        <span class="marquee-text">{text}</span>
        <span class="announcement-suit">♦</span>
        <span class="marquee-text">{text}</span>
      </div>
    </div>
    <!-- Screen-reader text, hidden visually (marquee is aria-hidden) -->
    <p class="sr-only">{text}</p>
    <a
      href={ctaHref}
      target="_blank"
      rel="noopener noreferrer"
      class="announcement-cta announcement-cta-mobile"
      id="announcement-cta-link-mobile"
    >
      <span>{ctaText}</span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="announcement-cta-arrow"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
      </svg>
    </a>
  </div>

  <!-- Desktop: static centered layout -->
  <div class="announcement-desktop">
    <span class="announcement-suit" aria-hidden="true">♦</span>
    <p class="announcement-text">{text}</p>
    <a
      href={ctaHref}
      target="_blank"
      rel="noopener noreferrer"
      class="announcement-cta"
      id="announcement-cta-link-desktop"
    >
      <span>{ctaText}</span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="announcement-cta-arrow"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
      </svg>
    </a>
    <span class="announcement-suit" aria-hidden="true">♦</span>
  </div>
</div>

<style>
  /* ── Shared banner shell ─────────────────────────────────── */
  .announcement-banner {
    background-color: #7a1c1c;
    background-image: repeating-linear-gradient(
      90deg,
      transparent,
      transparent 40px,
      rgba(255, 255, 255, 0.03) 40px,
      rgba(255, 255, 255, 0.03) 41px
    );
    border-bottom: 1px solid rgba(255, 220, 180, 0.15);
    width: 100%;
    overflow: hidden;
  }

  /* ── Suit ornaments ──────────────────────────────────────── */
  .announcement-suit {
    font-family: var(--font-serif-title, Georgia, serif);
    font-size: 0.6rem;
    color: rgba(255, 220, 180, 0.35);
    flex-shrink: 0;
    user-select: none;
  }

  /* ── CTA button (shared) ─────────────────────────────────── */
  .announcement-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-sans-ui, sans-serif);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #ffd9a0;
    white-space: nowrap;
    text-decoration: none;
    border: 1px solid rgba(255, 217, 160, 0.4);
    border-radius: 2px;
    padding: 0.2rem 0.55rem;
    flex-shrink: 0;
    transition: background-color 0.15s, color 0.15s, border-color 0.15s;
  }

  .announcement-cta:hover {
    background-color: rgba(255, 217, 160, 0.12);
    border-color: rgba(255, 217, 160, 0.7);
    color: #ffe8c0;
  }

  .announcement-cta:hover .announcement-cta-arrow {
    transform: translateX(2px);
  }

  .announcement-cta-arrow {
    width: 0.7rem;
    height: 0.7rem;
    transition: transform 0.15s;
  }

  /* ── MOBILE layout (default) ─────────────────────────────── */
  .announcement-mobile {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-bottom: 0.45rem;
    overflow: hidden;
  }

  .announcement-desktop {
    display: none;
  }

  /* Marquee track: fills remaining space, clips overflow */
  .marquee-track {
    flex: 1;
    overflow: hidden;
    /* subtle right fade so text doesn't crash into the CTA */
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 6%, black 88%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, black 6%, black 88%, transparent 100%);
  }

  /* The scrolling strip — duplicated text creates a seamless loop */
  .marquee-content {
    display: flex;
    align-items: center;
    gap: 1rem;
    width: max-content;
    padding: 0.5rem 0 0.35rem;
    animation: marquee-scroll 22s linear infinite;
  }

  .marquee-text {
    font-family: var(--font-serif-body, Georgia, serif);
    font-size: 0.8rem;
    color: rgba(255, 240, 220, 0.92);
    white-space: nowrap;
    line-height: 1.4;
  }

  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* CTA below marquee on mobile */
  .announcement-cta-mobile {
    font-size: 0.6rem;
    padding: 0.1rem 0.4rem;
    border-color: rgba(255, 217, 160, 0.3);
  }

  /* Pause marquee if user prefers reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .marquee-content {
      animation: none;
    }
    .marquee-track {
      -webkit-mask-image: none;
      mask-image: none;
    }
  }

  /* ── DESKTOP layout (≥ 640px) ────────────────────────────── */
  @media (min-width: 640px) {
    .announcement-mobile {
      display: none;
    }

    .announcement-desktop {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      padding: 0.6rem 1rem;
      max-width: 64rem;
      margin: 0 auto;
    }

    .announcement-text {
      font-family: var(--font-serif-body, Georgia, serif);
      font-size: 0.85rem;
      color: rgba(255, 240, 220, 0.92);
      text-align: center;
      margin: 0;
      line-height: 1.4;
      white-space: nowrap;
    }
  }
</style>
