---
import Layout from '../layouts/Layout.astro';

const eventCategories = [
  {
    title: "Board Games",
    icon: "meeple",
    when: "Every Thursday Night (and the occasional weekend)"
  },
  {
    title: "Magic: The Gathering",
    icon: "mtg",
    when: "Every Saturday Night"
  },
  {
    title: "Tabletop Role Playing Games",
    icon: "d20",
    when: "One-shot adventures on weekends (when possible)"
  }
];

const channels = [
  {
    title: "WhatsApp",
    href: "/whatsapp",
    icon: "whatsapp",
    isExternal: false,
    action: "Join Chat Groups"
  },
  {
    title: "Discord",
    href: "/chat",
    icon: "discord",
    isExternal: false,
    action: "Join Server"
  },
  {
    title: "Instagram",
    href: "https://instagram.com/ReRollBLR",
    icon: "instagram",
    isExternal: true,
    action: "Follow"
  },
  {
    title: "BoardGameGeek Guild",
    href: "/bgg",
    icon: "bgg",
    isExternal: false,
    action: "Join Guild"
  }
];
---

<Layout title="Hello!" tagline="“Which is just a fancy way of saying we are a couple of friends who play board games and have a lot of free time.”">
  <section class="mb-20">
    <div class="flex items-center gap-4 mb-8">
      <h2 class="font-serif-title text-xl md:text-2xl font-bold text-brand-red tracking-wide whitespace-nowrap uppercase">
        What We Play
      </h2>
      <div class="h-[1px] w-full bg-brand-red/10"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {eventCategories.map(event => (
        <div class="card-lift-shadow bg-[#FAF8F5] border border-brand-red/20 rounded-xs hover:border-brand-red relative group overflow-hidden flex flex-col min-h-[280px] transition-all duration-300">
          
          <!-- Double border effect inside the card to represent a tactile playing card -->
          <div class="border border-dashed border-brand-red/10 group-hover:border-brand-red/25 p-6 m-1 flex-1 flex flex-col items-center justify-center text-center transition-colors">
            
            <!-- Corner card suit emblems for that boardgame/vintage vibe -->
            <div class="absolute top-3.5 left-3.5 font-serif-title text-brand-red/15 text-xs select-none">♣</div>
            <div class="absolute top-3.5 right-3.5 font-serif-title text-brand-red/15 text-xs select-none">♦</div>
            <div class="absolute bottom-3.5 left-3.5 font-serif-title text-brand-red/15 text-xs select-none">♥</div>
            <div class="absolute bottom-3.5 right-3.5 font-serif-title text-brand-red/15 text-xs select-none">♠</div>
            <div class="mt-2 mb-4 p-4.5 bg-brand-red-pale rounded-full text-brand-red group-hover:scale-110 group-hover:bg-brand-red/10 transition-all duration-300">
              {event.icon === 'meeple' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 transition-transform duration-500 group-hover:rotate-12" viewBox="0 0 512 512">
                  <path fill="currentColor" d="M256 54.99c-27 0-46.418 14.287-57.633 32.23-10.03 16.047-14.203 34.66-15.017 50.962-30.608 15.135-64.515 30.394-91.815 45.994-14.32 8.183-26.805 16.414-36.203 25.26C45.934 218.28 39 228.24 39 239.99c0 5 2.44 9.075 5.19 12.065 2.754 2.99 6.054 5.312 9.812 7.48 7.515 4.336 16.99 7.95 27.412 11.076 15.483 4.646 32.823 8.1 47.9 9.577-14.996 25.84-34.953 49.574-52.447 72.315C56.65 378.785 39 403.99 39 431.99c0 4-.044 7.123.31 10.26.355 3.137 1.256 7.053 4.41 10.156 3.155 3.104 7.017 3.938 10.163 4.28 3.146.345 6.315.304 10.38.304h111.542c8.097 0 14.026.492 20.125-3.43 6.1-3.92 8.324-9.275 12.67-17.275l.088-.16.08-.166s9.723-19.77 21.324-39.388c5.8-9.808 12.097-19.576 17.574-26.498 2.74-3.46 5.304-6.204 7.15-7.754.564-.472.82-.56 1.184-.76.363.2.62.288 1.184.76 1.846 1.55 4.41 4.294 7.15 7.754 5.477 6.922 11.774 16.69 17.574 26.498 11.6 19.618 21.324 39.387 21.324 39.387l.08.165.088.16c4.346 8 6.55 13.323 12.61 17.254 6.058 3.93 11.974 3.45 19.957 3.45H448c4 0 7.12.043 10.244-.304 3.123-.347 6.998-1.21 10.12-4.332 3.12-3.122 3.984-6.997 4.33-10.12.348-3.122.306-6.244.306-10.244 0-28-17.65-53.205-37.867-79.488-17.493-22.74-37.45-46.474-52.447-72.315 15.077-1.478 32.417-4.93 47.9-9.576 10.422-3.125 19.897-6.74 27.412-11.075 3.758-2.168 7.058-4.49 9.81-7.48 2.753-2.99 5.192-7.065 5.192-12.065 0-11.75-6.934-21.71-16.332-30.554-9.398-8.846-21.883-17.077-36.203-25.26-27.3-15.6-61.207-30.86-91.815-45.994-.814-16.3-4.988-34.915-15.017-50.96C302.418 69.276 283 54.99 256 54.99z"/>
                </svg>
              )}
              {event.icon === 'mtg' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 transition-transform duration-500 group-hover:-rotate-12" viewBox="0 0 600 1204.1633">
                  <defs>
                    <clipPath id="clipPath3783">
                      <path d="M 0,300 147,300 147,0 0,0 0,300 z" />
                    </clipPath>
                  </defs>
                  <g transform="translate(-128.125,398.84217)">
                    <g transform="matrix(4.0816327,0,0,-4.0816327,128.125,815.48356)">
                      <g clip-path="url(#clipPath3783)">
                        <g transform="translate(145.458,184.2598)">
                          <path
                            d="m 0,0 c -1.245,32.734 -4.061,45.164 -5.927,45.164 -1.894,0 -2.49,-18.131 -4.979,-34.153 -2.49,-15.985 -6.874,-34.113 -6.874,-34.113 l -11.204,4.268 c 0,0 -3.141,23.131 -4.385,50.851 -1.216,27.721 -2.164,51.931 -5.63,51.931 -3.382,0.029 -4.031,-22.762 -5.276,-52.296 -1.246,-29.517 -5.601,-45.865 -5.601,-45.865 l -10.283,1.433 c 0,0 -4.98,25.602 -6.848,103.807 -0.433,18.509 -4.951,22.223 -4.951,22.223 0,0 -4.52,-3.714 -4.953,-22.223 -1.866,-78.205 -6.874,-103.807 -6.874,-103.807 l -10.257,-1.433 c 0,0 -4.382,16.348 -5.627,45.865 -1.245,29.534 -1.869,52.325 -5.276,52.296 -3.438,0 -4.386,-24.21 -5.659,-51.931 -1.216,-27.72 -4.33,-50.851 -4.33,-50.851 l -11.204,-4.268 c 0,0 -4.382,18.128 -6.872,34.113 -2.489,16.022 -3.113,34.153 -4.979,34.153 -1.868,0 -4.681,-12.43 -5.927,-45.164 -1.245,-32.693 -1.542,-39.084 -1.542,-39.084 0,0 36.777,-15.67 51.093,-56.223 14.343,-40.529 17.969,-75.72 18.077,-79.627 0.188,-6.064 4.33,-6.836 4.33,-6.836 0,0 3.6,0.772 4.33,6.836 0.459,3.879 3.734,39.098 18.075,79.627 14.318,40.553 51.095,56.223 51.095,56.223 0,0 -0.299,6.391 -1.542,39.084"
                            fill="currentColor"
                            stroke="none"
                          />
                        </g>
                      </g>
                    </g>
                  </g>
                </svg>
              )}
              {event.icon === 'd20' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 transition-transform duration-500 group-hover:rotate-45" viewBox="0 0 512 512">
                  <path fill="currentColor" d="M248 20.3L72 132.6l176-3.8V20.3zm16 0v108.5l175.7 3.8L264 20.3zm43.1 49.97c2.8.06 5.8.75 9.2 2.08 2.3.91 4.1 1.91 5.6 3.07 1.5 1.15 2.8 2.5 3.7 3.79 1.5 2.06 2.2 4.04 2.6 6.25 2.4-1.77 5.2-2.98 8.2-3.84 3.4-.73 7.2-.35 11.1 1.23 4.6 1.82 8.1 4.19 10.3 7.11 2.2 2.93 3.5 5.97 4 9.13.3 1.71.3 3.41.1 5.01-.1 1.7-.6 3.3-1.2 4.7-.5 1.5-1.2 3-2.3 4.3-1 1.3-2.1 2.6-3.5 3.6-2.5 2-5.5 3.3-9.1 3.9-3.6.6-7.7 0-12.3-1.8-4-1.6-7-3.8-9-6.7-1.6-2.6-2.9-5.5-3.4-8.4-2 1.5-4.2 2.5-6.9 2.9-3 .6-6.5 0-10.7-1.6-2.4-1-4.5-2.1-6.2-3.3-1.8-1.3-3.2-2.61-4.3-4.08-2.1-2.58-3.2-5.37-3.5-8.35-.2-2.9.2-5.65 1.1-8.15.5-1.29 1.3-2.57 2.1-3.92 1-1.1 2-2.21 3.1-3.26 2.4-1.77 5.2-2.97 8.5-3.53.9-.12 1.8-.17 2.8-.14zM208 75.56c4.8.05 10.9 3.57 9 10.04-4 6.9-10.3 12.17-18 14.8-7.4 2.5-15 4.4-22 1.9-3-2.3-13-9.4-15-3.4-1.2 15.3 1 13-11 17.8V92.3c10-3.9 21-4.5 31 1.3 8 4.2 19 1.5 24-5.8 1-6.5-8-4.5-12-3.3-3-8.3 7.8-8.43 13-8.9.3-.03.6-.04 1-.04zm100.5 4.46c-.9.01-1.8.14-2.8.36-2.4.61-4.2 2.17-5.1 4.67-1 2.42-.8 4.74.6 6.88 1.4 2.22 3.3 3.73 6 4.78 2.9 1.15 5.4 1.41 8 .73 2.5-.56 4.3-2.12 5.2-4.54 1-2.5.8-4.82-.7-7.01-1.4-2.14-3.5-3.77-6.4-4.92-1.6-.66-3.2-.96-4.8-.95zm28.9 10.15c-1.1.05-2.2.27-3.2.65-2.7 1.17-4.5 2.96-5.4 5.39-1 2.5-.9 5.09.4 7.59 1.2 2.6 3.6 4.6 7.2 6.1 2.9 1.1 5.8 1.3 8.6.6 2.8-.8 4.7-2.7 5.8-5.6 1.1-2.9 1.1-5.53-.5-8.01-1.5-2.47-3.7-4.37-6.6-5.51-2.3-.9-4.4-1.29-6.3-1.21zM242 144.9L55 149l72 192.9 115-197zm28 0l115.4 197L456.6 149 270 144.9zm-14 7.5L139 352.6h234.1L256 152.4zm116.6 16.4l19.2 42.5 7.2-3.3 4.1 9.2-7.1 3.2 6.3 14-10.4 4.7-6.3-14-30.2 13.6-3.9-8.7c1.4-9.2 4.4-27.8 8.9-55.7l1.8-.8.8-.3 3.1-1.5 6.5-2.9zm-225.9 12.1h1.3c2.9 0 5.5.5 7.8 1.6 6.9 3.2 10.7 8.4 11.7 15.3.9 6.9-1 15.3-5.7 25.1-4.7 9.7-10 16.5-15.8 20.3-6 3.8-12.3 4.1-19.1 1-5.9-2.8-9.4-6.7-10.6-11.9-1.2-5.3-.9-9.7.9-13.5l9.6 4.4c-.9 1.7-1.1 3.8-.8 6.3.3 2.6 1.9 4.5 5 6 3.1 1.4 6.1 1.3 9.2-.2 3.1-1.4 6.3-5.2 9.7-11.3.5-1 1.1-2.1 1.7-3.3-1.8 1.2-3.6 2-5.5 2.6-3.2.9-6.6.5