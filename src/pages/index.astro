2 3.4-3.1 7-4.2 10.9-4.2zm33.1.7s1 .1 1 .2c4 .8 7 .3 10 .4h25.6c1.5 3 .8 7.8-3.3 7.9-3.9.5-7.8-.4-11.7.2-4.7.2-9.6-1.8-14.6.4-3 1.7-4 8.5 1 6.1 4-1.1 7.3-1.8 10.8-.9 7 1.1 15 2.9 19.1 9.2 2.1 3.1 2.7 7.3.7 10.7-3.6 6.5-11.6 8.4-18.3 9.7-2.4.4-4.7 1.4-7.3 1.2-7-.6-15-1.1-20-7.1-3-2.5-3-7.1 2-6.7 3-.1 8-.4 10 3.5 3 3.7 9 3 13 2 3.6-.5 7.5-2.6 7.6-6.7.6-4.2-3.1-7.2-6.9-7.8-5.7-2.3-11.7 1.4-17.7 1.8-3 1.1-9 .5-9-4.4 1-4.2 3-8.1 3-12.5 0-3 2-7 5-7.2zm133.5 5c-.2-.2-7 5.8-9.9 8.1l-15.8 13.1c8.6-4.4 16.5-9.6 22.3-17.4 2.6-2.6 3.5-3.7 3.4-3.8zM151 405.5c3 0 8 4.6 10 7l26 31.1c-8-2.1-13-7.1-18-13.7-6-7.3-11-16.6-21-19.6-9-5-5-6.4 2-2.2 0-1.9 0-2.6 1-2.6z"/>
                </svg>
              )}
            </div>
            <h3 class="font-serif-title text-xl md:text-2xl font-extrabold text-brand-red group-hover:text-brand-red-dark transition-colors tracking-wide uppercase leading-tight flex items-center justify-center">
              {event.title}
            </h3>
            
            <p class="font-serif-body text-sm italic text-text-ink-muted mt-3 group-hover:text-text-ink transition-colors max-w-[200px]">
              {event.when}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Centered View Schedule Button -->
    <div class="flex justify-center mt-12">
      <a 
        href="https://at.underline.center/reroll-calendar-website"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 bg-brand-red hover:bg-brand-red-dark text-[#FAF6F0] font-sans-ui text-xs tracking-widest uppercase font-bold py-4 px-8 rounded-xs transition-colors duration-200 card-lift-shadow border border-brand-red/10 group"
      >
        <span>View Schedule</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
        </svg>
      </a>
    </div>
  </section>

  <section class="mb-12 max-w-2xl mx-auto text-center border border-dashed border-brand-red/25 bg-brand-red-pale/50 p-6 rounded-xs relative group hover:border-brand-red transition-colors">
    <div class="absolute top-3.5 left-3.5 font-serif-title text-brand-red/10 text-xs select-none">♣</div>
    <div class="absolute top-3.5 right-3.5 font-serif-title text-brand-red/10 text-xs select-none">♦</div>
    <div class="absolute bottom-3.5 left-3.5 font-serif-title text-brand-red/10 text-xs select-none">♥</div>
    <div class="absolute bottom-3.5 right-3.5 font-serif-title text-brand-red/10 text-xs select-none">♠</div>
    
    <h3 class="font-serif-title text-lg md:text-xl font-extrabold text-brand-red tracking-wide uppercase mb-3">
      Our Code of Conduct
    </h3>
    <p class="font-serif-body text-sm md:text-base leading-relaxed text-text-ink mb-4 max-w-lg mx-auto">
      ReRoll is a friendly, safe, and welcoming space for all players. We expect everyone at our tables to treat others with patience and kindness, respect shared board games, and keep our community inclusive and harassment-free.
    </p>
    <a 
      href="/code-of-conduct" 
      class="inline-flex items-center gap-1.5 font-sans-ui text-2xs tracking-widest uppercase font-bold text-brand-red hover:text-brand-red-dark transition-colors group/link"
    >
      <span>Read the Full Rulebook</span>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 transform group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
      </svg>
    </a>
  </section>

  <section class="mb-12">
    <div class="flex items-center gap-4 mb-8">
      <h2 class="font-serif-title text-xl md:text-2xl font-bold text-brand-red tracking-wide whitespace-nowrap uppercase">
        Us, Elsewhere
      </h2>
      <div class="h-[1px] w-full bg-brand-red/10"></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4">
      {channels.map(card => (
        <a 
          href={card.href}
          target={card.isExternal ? "_blank" : undefined}
          rel={card.isExternal ? "noopener noreferrer" : undefined}
          class="card-lift-shadow block bg-[#FAF8F5] border border-brand-red/20 rounded-xs hover:border-brand-red relative group overflow-hidden"
        >
          <div class="border border-dashed border-brand-red/10 group-hover:border-brand-red/30 p-4 m-1 flex flex-col items-center text-center transition-colors h-full">
            
            <div class="p-3 bg-brand-red-pale rounded-full text-brand-red mb-3 group-hover:scale-110 transition-transform duration-300">
              {card.icon === 'discord' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
